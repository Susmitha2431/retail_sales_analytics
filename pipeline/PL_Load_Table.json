{
	"name": "PL_Load_Table",
	"properties": {
		"activities": [
			{
				"name": "LKP_GetWatermark",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "@concat(\r\n'SELECT WatermarkValue\r\nFROM control.Watermark\r\nWHERE TableName = ''',\r\npipeline().parameters.TableName,\r\n''''\r\n)",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "DS_SQL_CONTROL",
						"type": "DatasetReference"
					}
				}
			}
		],
		"parameters": {
			"TableName": {
				"type": "string"
			},
			"SourceSchema": {
				"type": "string"
			},
			"SourceTable": {
				"type": "string"
			},
			"SinkFolder": {
				"type": "string"
			},
			"LoadType": {
				"type": "string"
			}
		},
		"variables": {
			"WatermarkValue": {
				"type": "String"
			},
			"DynamicQuery": {
				"type": "String"
			},
			"RowsCopied": {
				"type": "Integer"
			}
		},
		"annotations": []
	}
}