{
	"name": "csvfiles",
	"properties": {
		"linkedServiceName": {
			"referenceName": "LS_ADLS",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"FileName": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@dataset().FileName",
					"type": "Expression"
				},
				"folderPath": "seed_data",
				"fileSystem": "retail"
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": [
			{
				"name": "CustomerID",
				"type": "String"
			},
			{
				"name": "FirstName",
				"type": "String"
			},
			{
				"name": "LastName",
				"type": "String"
			},
			{
				"name": "Email",
				"type": "String"
			},
			{
				"name": "City",
				"type": "String"
			},
			{
				"name": "CreatedDate",
				"type": "String"
			}
		]
	}
}